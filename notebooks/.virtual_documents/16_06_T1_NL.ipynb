# Asymmetric piecewise linear function
def f_asym(u,ub_pos=0.1,ub_neg=0.05,yb_pos=0.05,yb_neg=0.05,gain_outer=2):
    y = np.zeros_like(u)
    inner = (u >= -ub_neg) & (u <= ub_pos)
    y[inner] = (u[inner] + ub_neg)*(yb_pos + yb_neg)/(ub_pos + ub_neg) - yb_neg

    pos = (u > ub_pos)
    y[pos] = yb_pos + gain_outer*(u[pos]-ub_pos)

    neg = (u < -ub_neg)
    y[neg] = -yb_neg + gain_outer*(u[neg]+ub_neg)
    return y


# Specific NL for the audio example
ub = 0.15
yb = 0.0
ub_neg = 0.1
yb_neg = 0.0
gain_outer = ((1-yb)/(1-ub)) # chosen to ensure that OL output is 1 at input of 1

uu = np.linspace(-0.5,0.5,200)
f_of_u = f_asym(uu,ub_pos=ub,ub_neg=ub_neg,yb_pos=yb,yb_neg=yb_neg,gain_outer=gain_outer)



def closed_loop_pwl_asym(r, k, ub_pos=0.1,ub_neg=0.05,yb_pos=0.05,yb_neg=0.05,g_out=2):
    """
    Fully vectorized closed-form solution of
        y = f(k*(r - y))
    where f is your piecewise linear function.

    r: input array
    k: scalar gain
    ub, yb, g_out: nonlinearity parameters
    """
    r = np.asarray(r, dtype=float)
    y = np.zeros_like(r)

    # inner region formula
    rb_pos = break_points_in_r(k, ub_pos, yb_pos)
    rb_neg = break_points_in_r(k, ub_neg, yb_neg)
    inner = (r >= -rb_neg) & (r <= rb_pos)

    g_inner = (yb_pos + yb_neg)/(ub_pos + ub_neg)
    gain_inner_factor = (g_inner*k) / (1 + g_inner*k)
    y_inner = gain_inner_factor * (r[inner] + rb_neg) - yb_neg
    y[inner] = y_inner

    # positive outer region
    pos = r > rb_pos
    gain_outer_factor = (g_out*k) / (1 + g_out*k)
    offset_outer = (yb_pos - g_out*ub_pos) / (1 + g_out*k)
    y[pos] = gain_outer_factor * r[pos] + offset_outer

    # negative outer region
    neg = r < -rb_neg
    offset_outer_neg = -(yb_neg - g_out*ub_neg) / (1 + g_out*k)
    y[neg] = gain_outer_factor * r[neg] + offset_outer_neg

    return y


gains = [2,5,20]
for kk, gain in enumerate(gains):
    fcl_of_r = closed_loop_pwl_asym(uu, gain,ub_pos=ub,ub_neg=ub_neg,yb_pos=yb,yb_neg=yb_neg,g_out=gain_outer)    

    fig, ax = plt.subplots(1, figsize=(4, 4), dpi=150, constrained_layout=True)

    ax.plot(uu, f_of_u, 'b', label=r'NL $f(r)$', lw=0.75)
    ax.plot(uu, uu, color='k', label=r'$g = r$', lw=0.75, ls=':')
    ax.plot(uu, fcl_of_r, color=colors[kk+1], label=r'$g_{CL}$, $k = $' + str(gain), lw=0.75)

    ax.axvline(x=ub, ls='--', c='b', lw=0.75)
    ax.axvline(x=-ub_neg, ls='--', c='b', lw=0.75)
    bp_pos = break_points_in_r(gain, ub=ub, yb=yb)
    bp_neg = break_points_in_r(gain, ub=ub_neg, yb=yb_neg)
    ax.axvline(x=bp_pos, ls='--', c=colors[kk+1], lw=0.75)
    ax.axvline(x=-bp_neg, ls='--', c=colors[kk+1], lw=0.75)

    ax.set_xlabel(r'$r$')
    ax.set_ylabel(r'$y = g(r)$')
    ax.set_title("Audio Feedback Gain: " + str(gain))

    dim = max(abs(uu))
    ax.set_xlim([-dim, dim])
    ax.set_ylim([-dim, dim])
    ax.set_aspect('equal')
    
    bm.nicegrid(ax)
    ax.legend()

    fig.savefig("./figs/Lect1_audio_" + str(gain) + ".pdf", dpi=600)
    plt.show()


