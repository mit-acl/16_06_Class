# Define the piecewise linear function
ub = 0.25 # input break point
yb = 0.05 # output break point
gain_outer = 2

def f(u,ub=0.25,yb=0.05,gain_outer=2): # the piecewise linear function
    y = np.zeros_like(u)
    inner = (u >= -ub) & (u <= ub)
    y[inner] = yb*(u[inner]/ub)

    pos = (u > ub)
    y[pos] = yb + gain_outer*(u[pos]-ub)

    neg = (u < -ub)
    y[neg] = -yb + gain_outer*(u[neg]+ub)
    return y

# Generate data for plotting
uu = np.linspace(-1,1,200)
f_of_u = f(uu)

# plot the function
fig, ax = plt.subplots(1,figsize=(4, 4),dpi=150,constrained_layout = True)
plt.plot(uu,f_of_u,'b')
plt.xlabel('u')
plt.ylabel('y=f(u)')
plt.axvline(x=ub, color='b', linestyle='--', linewidth=0.8)
plt.plot(uu, uu, color='k', label=r'$g = r$', lw=0.75)
plt.axvline(x=-ub, color='b', linestyle='--', linewidth=0.8)
plt.xlim([-1, 1])
plt.ylim([-1, 1])
plt.gca().set_aspect('equal')
bm.nicegrid(ax)
plt.title('Piecewise Linear Function')
fig.savefig("./figs/Lect1_" + str(0) + ".pdf", dpi=600)
plt.show()





# Functions to compute gains and break points of closed loop systems
# Compute break points in r for given gain k
# Break points occur when u = ±ub
# ub = k*(rb - yb) → rb = ub/k + yb
def break_points_in_r(k, ub=0.25, yb=0.05):
    return yb + ub/k

# closed loop gain in middle section between the break points ±rb
# at rb input, output is yb
# middle section gain = yb/rb = yb/(yb + ub/k) = (yb/ub)*k / (1 + (yb/ub)*k)
def middle_gain(k, ub=0.25, yb=0.05):
    l = (yb/ub)*k
    return l/(1+l)

gains = [2,5,20]
for gain in gains: 
    print(r"For k = "+str(gain)+f" Break points: {break_points_in_r(gain):4.3f}")
    print(r"For k = "+str(gain)+f" Middle Gain: {middle_gain(gain):4.3f}\n")


def closed_loop_pwl(r, k, ub=0.25, yb=0.05, g_out=2.0):
    """
    Fully vectorized closed-form solution of
        y = f(k*(r - y))
    where f is your piecewise linear function.

    r: input array
    k: scalar gain
    ub, yb, g_out: nonlinearity parameters
    """

    r = np.asarray(r, dtype=float)
    y = np.zeros_like(r)

    # inner region formula
    rb = break_points_in_r(k, ub, yb)
    inner = np.abs(r) <= rb
    gain_inner_factor = middle_gain(k, ub, yb)
    y_inner = gain_inner_factor * r
    y[inner] = y_inner[inner]

    # positive outer region
    pos = r > rb
    gain_outer_factor = (g_out*k) / (1 + g_out*k)
    offset_outer = (yb - g_out*ub) / (1 + g_out*k)
    y[pos] = gain_outer_factor * r[pos] + offset_outer

    # negative outer region
    neg = r < -rb
    offset_outer_neg = -(yb - g_out*ub) / (1 + g_out*k)
    y[neg] = gain_outer_factor * r[neg] + offset_outer_neg

    return y


for kk, gain in enumerate(gains):

    fig, ax = plt.subplots(1, figsize=(4, 4), dpi=150, constrained_layout=True)

    ax.plot(uu, f_of_u, 'b', label=r'NL $f(r)$', lw=0.75)
    ax.plot(uu, uu, color='k', label=r'$g = r$', lw=0.75)
    ax.plot(uu, closed_loop_pwl(uu, gain), color=colors[kk+1],
            label=r'$g_{CL}$, $k = $' + str(gain))

    ax.axvline(x=ub, ls='--', c='b', lw=0.75)
    ax.axvline(x=-ub, ls='--', c='b', lw=0.75)
    bp = break_points_in_r(gain)
    ax.axvline(x=bp, ls='--', c=colors[kk+1], lw=0.75)
    ax.axvline(x=-bp, ls='--', c=colors[kk+1], lw=0.75)

    ax.set_xlabel(r'$r$')
    ax.set_ylabel(r'$y = g(r)$')
    ax.set_title("Feedback Gain: " + str(gain))

    ax.set_xlim([-1, 1])
    ax.set_ylim([-1, 1])
    ax.set_aspect('equal')
    
    bm.nicegrid(ax)
    ax.legend()

    fig.savefig("./figs/Lect1_" + str(gain) + ".pdf", dpi=600)
    plt.show()








from IPython.display import Audio, display, Markdown


def load_audio(filename):
    from pydub import AudioSegment
    import numpy as np

    audio = AudioSegment.from_file(filename)
    fs = audio.frame_rate
    x = np.array(audio.get_array_of_samples()).astype(float)

    if audio.channels > 1:
        x = x.reshape((-1, audio.channels)).mean(axis=1)

    x /= np.max(np.abs(x)) + 1e-12
    return x, fs


